# Copy to .env and adjust for your environment.
# docker-compose reads these automatically.

# --- PostgreSQL ---
POSTGRES_USER=kiewit
POSTGRES_PASSWORD=kiewit
POSTGRES_DB=kiewit

# --- MinIO (S3-compatible storage) ---
# IMPORTANT: change these credentials before deploying to production.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kiewit-resumes

# Public host baked into presigned upload/download URLs (must be reachable by the
# browser). Locally this is localhost:9000. In production set it to your public
# MinIO host/domain, e.g. MINIO_PUBLIC_ENDPOINT=files.example.com + USE_SSL=true.
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000
MINIO_PUBLIC_USE_SSL=false
# CORS origin allowed to upload directly to MinIO ("*" for local dev).
MINIO_CORS_ORIGIN=*

# --- Server (only needed when running the server outside Docker) ---
# PORT=3001
# DATABASE_URL=postgres://kiewit:kiewit@localhost:5432/kiewit
# MAX_UPLOAD_BYTES=10485760
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
